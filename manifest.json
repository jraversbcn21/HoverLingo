{
  "manifest_version": 3,
  "name": "HoverLingo",
  "version": "0.1.0",
  "description": "Traducción instantánea al colocar el cursor sobre cualquier palabra",
  "permissions": ["storage"],
  "host_permissions": ["https://api.groq.com/*"],
  "commands": {
    "toggle-hoverlingo": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle HoverLingo on/off"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "HoverLingo"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
